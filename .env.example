# Postgres Configuration
DATABASE_URL=postgresql://edk_user:your_postgres_password_here@localhost:5432/edk

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# zKillboard RedisQ ID (Optional)
REDISQ_ID=

# Application Configuration (Optional)
NODE_ENV=development
THEME=default
SITE_TITLE=EVE-KILL
SITE_SUBTITLE=Real-time Killmail Tracking
IMAGE_SERVER_URL=https://images.evetech.net
ESI_SERVER_URL=https://esi.evetech.net

# Followed Entities (Optional, comma-separated lists of IDs)
FOLLOWED_CHARACTER_IDS=
FOLLOWED_CORPORATION_IDS=
FOLLOWED_ALLIANCE_IDS=

# Test Database Configuration (Optional, for running tests)
TEST_DB_NAME=edk_test
DB_USER=edk_user
DB_PASSWORD=edk_password
DB_HOST=localhost
DB_PORT=5432
POSTGRES_DB=edk
ADMIN_DB_NAME=edk
ADMIN_DATABASE_URL=postgresql://edk_user:edk_password@localhost:5432/edk
